{
	"name": "obsidian-music-player-plugin",
	"version": "1.3.1",
	"description": "Play local music files from the vault in the sidebar.",
	"main": "main.js",
	"type": "module",
	"author": "Kevin",
	"repository": {
		"type": "git",
		"url": "https://github.com/TracingOrigins/obsidian-music-player-plugin.git"
	},
	"scripts": {
		"dev": "node scripts/deploy.mjs dev && node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node scripts/deploy.mjs build",
		"version": "node version-bump.mjs && git add package.json manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"Music",
		"Music Player",
		"Obsidian Plugin"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"@types/react": "^18.2.0",
		"@types/react-dom": "^18.2.0",
		"@typescript-eslint/utils": "^8.54.0",
		"buffer": "^6.0.3",
		"esbuild": "0.25.5",
		"eslint": "^9.39.2",
		"eslint-plugin-obsidianmd": "0.1.9",
		"events": "^3.3.0",
		"globals": "14.0.0",
		"music-metadata-browser": "^2.5.11",
		"process": "^0.11.10",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
